# Trade Lane Risk Monitor — API keys
# Copy this file to ".env" and fill in any keys you have. ALL keys are OPTIONAL:
# the app falls back to free, no-key sources when a key is missing.

# EIA (U.S. Energy Information Administration) — free Brent crude data.
# Get one at: https://www.eia.gov/opendata/register.php
# If unset, the app falls back to Stooq's free CSV feed.
EIA_API_KEY=

# NewsAPI.org — free developer tier for news headlines.
# Get one at: https://newsapi.org/register
# If unset, the app falls back to Google News RSS (no key needed).
NEWSAPI_KEY=
